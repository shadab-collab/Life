# ==============================
# SHADAB COACHING CENTRE V4
# Environment Configuration
# ==============================

# Application
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/shadab_coaching_v4?retryWrites=true&w=majority

# App Information
APP_NAME=Shadab Coaching Centre
APP_VERSION=4.0.0

# Timezone
TZ=Asia/Kolkata

# Receipt Settings
RECEIPT_START_NUMBER=1001

# Upload Directories
UPLOAD_DIR=uploads
BACKUP_DIR=backups
EXPORT_DIR=exports

# CORS
CORS_ORIGIN=*

# Future Features (Reserved)
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
WHATSAPP_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=